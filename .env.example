# Google Cloud OAuth 2.0 Client ID (Web application type).
# Google Cloud Console → APIs & Services → Credentials → Create Credentials → OAuth client ID
VITE_GOOGLE_CLIENT_ID=

# Google Cloud API key, used by the Google Picker to browse Drive.
# Google Cloud Console → APIs & Services → Credentials → Create Credentials → API key
VITE_GOOGLE_API_KEY=

# Optional: Google Cloud project number, only needed if you see Picker
# "appId" warnings in the console.
VITE_GOOGLE_APP_ID=
